<odoo>

    <record id="view_fee_payment_wizard_form" model="ir.ui.view">
        <field name="name">fee.payment.wizard.form</field>
        <field name="model">fee.payment.wizard</field>
        <field name="arch" type="xml">
            <form string="Fee Payment Report">
                <group>
                    <field name="academic_id"/>
                    <field name="student_id"/>
                </group>

                <footer>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fee_payment_wizard" model="ir.actions.act_window">
        <field name="name">Fee Payment Report</field>
        <field name="res_model">fee.payment.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_schools_reports" name="Reports" parent="menu_school_root" sequence="5"/>
    <menuitem id="menu_fee_payment_reports" name="Fee Payment Report" parent="menu_schools_reports" action="action_fee_payment_wizard"/>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_card_pdf" model="ir.actions.report">
        <field name="name">Report Card</field>
        <field name="model">school.exam.result</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">at_school_management.report_school_report_card</field>
        <field name="report_file">at_school_management.report_school_report_card</field>
        <field name="print_report_name">"Report Card"</field>
        <field name="binding_model_id" ref="model_school_exam_result"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_school_report_card">
        <t t-call="at_school_management.report_card_result_lines"/>
    </template>

    <template id="report_card_result_lines">
    <t t-call="web.html_container">
        <t t-call="web.external_layout">

            <t t-foreach="docs" t-as="doc">
                
                <!-- Header -->
                <div class="page">
                    <h2>Report Card</h2>

                    <!-- Customer Info -->
                    <div>
                        <strong>Student:</strong>
                        <span t-esc="doc.get('student_id').name"/>
                        <br/>
                        <strong>Class:</strong>
                        <!-- <span t-esc="doc.class_id.name"/> -->
                    </div>

                    <br/>

                    <!-- Payment Details -->
                    <h3>Details</h3>
                    <table class="table table-sm">
                        <tr>
                            <td><strong>Reference</strong></td>
                            <td></td>
                        </tr>
                        <tr>
                            <td><strong>Date</strong></td>
                            <!-- <td><span t-esc="doc.date"/></td> -->
                        </tr>
                        <!-- <tr>
                            <td><strong>Amount</strong></td>
                            <td>
                                <span t-esc="doc.amount"
                                      t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Payment Method</strong></td>
                            <td><span t-esc="doc.payment_method_id.name"/></td>
                        </tr> -->
                    </table>

                    <br/>

                    <!-- Line Items -->
                    <h3>Fee Details:</h3>
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Item</th>
                                <th>Description</th>
                                <th>Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="i" t-value="1"/>
                            <t t-foreach="doc.get('data')" t-as="line">
                                <tr>
                                    <td><span t-esc="i"/></td>
                                    <td><span t-esc="line.fee_type_id.name"/></td>
                                    <td><span t-esc="line.description"/></td>
                                    <td>
                                        <span t-esc="line.amount"
                                              t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                    </td>
                                </tr>
                                <t t-set="i" t-value="i + 1"/>
                            </t>
                        </tbody>
                    </table>

                    <br/>

                </div>
            </t>
        </t>
    </t>
</template>

</odoo>

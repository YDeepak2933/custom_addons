<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_school_academic_tree" model="ir.ui.view">
        <field name="name">school.academic.year.tree</field>
        <field name="model">school.academic.year</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_school_academic_form" model="ir.ui.view">
        <field name="name">school.academic.year.form</field>
        <field name="model">school.academic.year</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    

    <record id="action_school_academic" model="ir.actions.act_window">
        <field name="name">Academic Year</field>
        <field name="res_model">school.academic.year</field>
        <field name="view_mode">list,form</field>
         <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Register a Academic Year!
              </p>
            </field>
    </record>

    <menuitem id="menu_school_academic" name="Academic Year" parent="menu_school_exam_root" action="action_school_academic"/>
</odoo>

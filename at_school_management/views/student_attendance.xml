<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_student_attendance_sheet_form" model="ir.ui.view">
        <field name="name">student.attendance.sheet.form</field>
        <field name="model">student.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance Sheet">
                <header>
                    <button name="action_done" string="Confirm" type="object" 
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Set to Draft" type="object" 
                            invisible="state != 'done'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state == 'done'"/>
                            <field name="class_id" readonly="state == 'done'" 
                                   options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="total_students"/>
                            <field name="total_present"/>
                            <field name="total_absent"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="line_ids" readonly="state == 'done'">
                                <list editable="bottom" create="false" delete="false">
                                    <field name="student_id"/>
                                    <field name="is_present" widget="boolean_toggle"/>
                                    <field name="remarks"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_student_attendance_sheet_tree" model="ir.ui.view">
        <field name="name">student.attendance.sheet.tree</field>
        <field name="model">student.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance Sheets" decoration-info="state == 'done'" decoration-muted="state == 'draft'">
                <field name="date"/>
                <field name="class_id"/>
                <field name="total_students"/>
                <field name="total_present"/>
                <field name="total_absent"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_student_attendance_sheet_search" model="ir.ui.view">
        <field name="name">student.attendance.sheet.search</field>
        <field name="model">student.attendance</field>
        <field name="arch" type="xml">
            <search string="Attendance">
                <field name="class_id"/>
                <field name="date"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Class" name="group_class" context="{'group_by':'class_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by':'date'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_student_attendance_sheet" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">student.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_date': 1}</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_student_attendance_sheet" name="Attendance" 
              parent="menu_school_exam_root" 
              action="action_student_attendance_sheet"/>
</odoo>
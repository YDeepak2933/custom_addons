<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_school_class_tree" model="ir.ui.view">
        <field name="name">school.class.tree</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="section"/>
                <field name="grade"/>
                <field name="academic_id"/>
                <field name="amount" sum="Sum of Total Fee"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_school_class_form" model="ir.ui.view">
        <field name="name">school.class.form</field>
        <field name="model">school.class</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="section"/>
                        <field name="grade"/>
                        <field name="academic_id"  />
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="students"/>
                        </page>
                        <page string="Fee Structure">
                            <field name="fee_structure_ids" mode="list">
                                <list editable="bottom">
                                    <field name="fee_type_id"  options="{'no_create': True}"/>
                                    <field name="description"/>
                                    <field name="amount" sum="Sum of Total Amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                            <field name="amount" invisible="1"/>
                        </page>
                     </notebook>
                </sheet>
            </form>
        </field>
    </record>
    

    <record id="action_school_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">school.class</field>
        <field name="view_mode">list,form</field>
         <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Register a class!
              </p>
            </field>
    </record>

    <menuitem id="menu_school_classes"
         name="Classes" 
         parent="menu_school_root" 
         action="action_school_class" 
         sequence="3"/>
</odoo>
